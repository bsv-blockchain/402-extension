{
  "manifest_version": 3,
  "name": "BSV 402 Payments",
  "version": "0.2.1",
  "description": "Automatically pays HTTP 402 responses using BSV micropayments (BRC-0121). Constructs and transmits a BSV blockchain transaction when a site requests payment. No personal data, bank details, or card information is collected or stored.",
  "background": {
    "scripts": [
      "dist/background.js"
    ]
  },
  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "bsv-402-payments@bsvblockchain.org",
      "strict_min_version": "115.0",
      "data_collection_permissions": {
        "required": [
          "financialAndPaymentInfo"
        ],
        "optional": [
          "technicalAndInteraction"
        ]
      }
    }
  }
}
